{
  "name": "feedcanon",
  "description": "Find the canonical URL for any web feed by comparing actual content. Turn messy feed URLs into their cleanest form.",
  "repository": {
    "type": "git",
    "url": "https://github.com/macieklamberski/feedcanon.git"
  },
  "homepage": "https://feedcanon.dev",
  "bugs": {
    "url": "https://github.com/macieklamberski/feedcanon/issues"
  },
  "license": "MIT",
  "author": "Maciej Lamberski",
  "sideEffects": false,
  "keywords": [
    "rss",
    "atom",
    "feed",
    "canonical",
    "url",
    "normalize",
    "dedupe"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/exports.d.ts",
      "default": "./dist/exports.js"
    },
    "./defaults": {
      "types": "./dist/defaults.d.ts",
      "default": "./dist/defaults.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prepare": "lefthook install",
    "build": "tsdown src/exports.ts src/defaults.ts --format esm --dts --clean --unbundle --no-fixed-extension",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs"
  },
  "dependencies": {
    "entities": "^8.0.0",
    "feedsmith": "^3.0.0-beta.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "kvalita": "1.12.4",
    "tsdown": "^0.21.7",
    "vitepress": "^2.0.0-alpha.17"
  }
}
